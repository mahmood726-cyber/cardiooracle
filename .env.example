# CardioOracle — environment template
#
# Copy this file to `.env` and fill in your AACT credentials.
# Register a free account at https://aact.ctti-clinicaltrials.org/users/sign_up
# AACT mirrors ClinicalTrials.gov as a PostgreSQL database; credentials are
# read by curate/shared.py::get_aact_connection.

AACT_USER=your_aact_username
AACT_PASSWORD=your_aact_password
